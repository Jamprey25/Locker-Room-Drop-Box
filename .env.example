# Copy to `.env` or `.env.local` so both Next.js and Prisma CLI see Postgres (never commit `.env`/`.env.local`).
#
# Docs: https://supabase.com/docs/guides/database/prisma
#
# RUNTIME (serverless) — Transaction pool (Supavisor), port ~6543:
DATABASE_URL="postgresql://postgres.PROJECT_REF:REPLACE_PASSWORD@YOUR_REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
#
# PRISMA ddlUrl — Session pool SAME host cluster, port 5432 (IPv4-friendly; avoids hang on txn :6543 and P1001 on db.* IPv6).
DIRECT_URL="postgresql://postgres.PROJECT_REF:REPLACE_PASSWORD@YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require"
#
# If IPv6 works, you MAY use DIRECT_URL=`…@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require` instead.

# Auth.js (`openssl rand -base64 32`). Required on Vercel prod.
AUTH_SECRET="paste-output-here"
# NEXTAUTH_SECRET="same-as-AUTH-if-you-prefer-nextauth-name"

# Alpha Vantage — live watchlist quotes (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY="your-alpha-vantage-key"

# Resend — meeting confirmation emails when 8/10 agree (https://resend.com)
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="Locker Room Dropbox <notifications@yourdomain.com>"
