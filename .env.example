# Prisma resolves relative to schema dir → `prisma/dev.db`. Supabase Postgres: use pooled `postgresql://...` + `provider = "postgresql"` in schema (README).
DATABASE_URL="file:dev.db"

# Auth.js (`openssl rand -base64 32`). Required on Vercel as `AUTH_SECRET` for prod JWTs.
AUTH_SECRET="paste-output-here"
# NEXTAUTH_SECRET="same-as-AUTH-if-you-prefer-nextauth-name"
