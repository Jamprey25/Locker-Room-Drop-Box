# Copy to `.env` or `.env.local` so both Next.js and Prisma CLI see Postgres (never commit `.env`/`.env.local`).
#
# RUNTIME / serverless bursts — Supabase transaction pooler (often :6543) + pgBouncer parity flags:
DATABASE_URL="postgresql://postgres.PROJECT_REF:REPLACE_PASSWORD@YOUR_POOL.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
#
# PRISMA DDL — `npm run db:push`, migrate, introspect use `directUrl` (NOT the pool). Use host `db.PROJECT_REF.supabase.co`, port **5432**:
DIRECT_URL="postgresql://postgres:REPLACE_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Auth.js (`openssl rand -base64 32`). Required on Vercel prod.
AUTH_SECRET="paste-output-here"
# NEXTAUTH_SECRET="same-as-AUTH-if-you-prefer-nextauth-name"
