generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  videosAdded    Video[]          @relation("VideoAddedBy")
  resourcesAdded Resource[]       @relation("ResourceAddedBy")
  videoWatches   VideoWatch[]
  watchlistAdded WatchlistItem[]  @relation("WatchlistAddedBy")
  expensesAdded  BusinessExpense[] @relation("ExpenseAddedBy")
  sharesAdded    SharePosition[]   @relation("ShareAddedBy")
  meetingsCreated Meeting[]        @relation("MeetingCreatedBy")
  meetingVotes    MeetingVote[]

  @@map("users")
}

model Video {
  id        String   @id @default(cuid())
  url       String   @unique
  title     String
  thumbnail String
  createdAt DateTime @default(now()) @map("created_at")
  addedById String   @map("added_by_id")
  addedBy   User     @relation("VideoAddedBy", fields: [addedById], references: [id], onDelete: Cascade)
  watches   VideoWatch[]

  @@index([addedById])
  @@map("videos")
}

model Resource {
  id        String   @id @default(cuid())
  url       String
  title     String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  addedById String   @map("added_by_id")
  addedBy   User     @relation("ResourceAddedBy", fields: [addedById], references: [id], onDelete: Cascade)

  @@index([addedById])
  @@map("resources")
}

/// One row per user per video once they tap "I've watched this"
model VideoWatch {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  videoId   String   @map("video_id")
  watchedAt DateTime @default(now()) @map("watched_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
  @@map("video_watches")
}

model WatchlistItem {
  id          String   @id @default(cuid())
  ticker      String   @unique
  companyName String   @map("company_name")
  sector      String
  type        String
  thesis      String   @default("")
  status      String   @default("Neutral")
  priority    String   @default("Neutral")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  addedById   String   @map("added_by_id")
  addedBy     User     @relation("WatchlistAddedBy", fields: [addedById], references: [id], onDelete: Cascade)

  @@index([sector])
  @@index([addedById])
  @@map("watchlist_items")
}

model BusinessExpense {
  id          String   @id @default(cuid())
  year        Int
  month       Int
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  addedById   String   @map("added_by_id")
  addedBy     User     @relation("ExpenseAddedBy", fields: [addedById], references: [id], onDelete: Cascade)

  @@index([year, month])
  @@index([addedById])
  @@map("business_expenses")
}

model SharePosition {
  id            String   @id @default(cuid())
  ticker        String
  companyName   String   @default("") @map("company_name")
  shareCount    Decimal  @map("share_count") @db.Decimal(14, 4)
  costBasis     Decimal  @map("cost_basis") @db.Decimal(14, 2)
  acquiredYear  Int?     @map("acquired_year")
  acquiredMonth Int?     @map("acquired_month")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  addedById     String   @map("added_by_id")
  addedBy       User     @relation("ShareAddedBy", fields: [addedById], references: [id], onDelete: Cascade)

  @@index([ticker])
  @@index([addedById])
  @@map("share_positions")
}

/// Singleton row (id = "default") for balance-sheet inputs
model AccountingSettings {
  id               String   @id @default("default")
  cashBalance      Decimal  @default(0) @map("cash_balance") @db.Decimal(14, 2)
  otherAssets      Decimal  @default(0) @map("other_assets") @db.Decimal(14, 2)
  totalLiabilities Decimal  @default(0) @map("total_liabilities") @db.Decimal(14, 2)
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("accounting_settings")
}

model Meeting {
  id           String        @id @default(cuid())
  title        String
  notes        String?
  scheduledAt  DateTime      @map("scheduled_at")
  status       String        @default("proposed")
  confirmedAt  DateTime?     @map("confirmed_at")
  emailsSentAt DateTime?     @map("emails_sent_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  createdById  String        @map("created_by_id")
  createdBy    User          @relation("MeetingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  votes        MeetingVote[]

  @@index([status])
  @@index([scheduledAt])
  @@index([createdById])
  @@map("meetings")
}

model MeetingVote {
  id        String   @id @default(cuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  agreed    Boolean  @default(true)
  votedAt   DateTime @default(now()) @map("voted_at")
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@map("meeting_votes")
}
